# Copy to .env.local and fill in. Never commit .env.local.

# Database (SQLite file, relative to the prisma/ dir)
DATABASE_URL="file:./dev.db"

# Auth — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# Email (Resend) — leave RESEND_API_KEY empty to disable sending (still saves enquiries)
RESEND_API_KEY=""
# From must use a Resend-verified domain in production, e.g. "MEPM <enquiries@mepmservices.co.uk>".
# onboarding@resend.dev works for testing before the domain is verified.
ENQUIRY_FROM="MEPM Website <onboarding@resend.dev>"
ENQUIRY_NOTIFY_TO="info@mepmservices.co.uk"
